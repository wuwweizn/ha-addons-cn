#!/bin/sh
set -e

TARGET="/homeassistant/custom_components"
HACS_DIR="${TARGET}/hacs"

echo "[INFO] =========================================="
echo "[INFO]   HACS 极速版 安装器"
echo "[INFO] =========================================="

mkdir -p "${TARGET}"

if [ -d "${HACS_DIR}" ]; then
    echo "[WARNING] 检测到已安装的 HACS，正在覆盖更新..."
    rm -rf "${HACS_DIR}"
fi

echo "[INFO] 正在安装 HACS 极速版..."
cp -rf /hacs "${HACS_DIR}"

echo "[INFO] 安装完成！请重启 Home Assistant 以激活 HACS 极速版。"
echo "[INFO] =========================================="
